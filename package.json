{
  "name": "@farhoodliquor/paperclip-adapter-hermes-k8s",
  "version": "0.3.3",
  "description": "Paperclip adapter plugin that runs Hermes agents as Kubernetes Jobs",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/farhoodliquor/paperclip-adapter-hermes-k8s"
  },
  "homepage": "https://github.com/farhoodliquor/paperclip-adapter-hermes-k8s#readme",
  "bugs": {
    "url": "https://github.com/farhoodliquor/paperclip-adapter-hermes-k8s/issues"
  },
  "paperclip": {
    "adapterUiParser": "1.0.0"
  },
  "exports": {
    ".": "./dist/index.js",
