    "@paperclipai/adapter-utils": "2026.411.0-canary.8",
    "@types/node": "^24.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "typescript": "^5.7.3",
    "vitest": "^4.1.4"
  }
}
